# Vizion - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# Frontend (Vite) - Required
# ===========================================

# Your Supabase project URL
# Get this from: Supabase Dashboard > Settings > API > Project URL
VITE_SUPABASE_URL=https://xrlkkppkphssvrorpzfx.supabase.co

# Your Supabase anon/public key
# Get this from: Supabase Dashboard > Settings > API > Project API keys > anon public
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_uH946akv32-ruNniuUzo2g_l84bdh-m

# ===========================================
# Supabase Edge Functions - Set in Supabase Dashboard
# ===========================================
# These are set in your Supabase Dashboard under:
# Settings > Edge Functions > Add new secret
#
# SUPABASE_URL - Automatically available in Edge Functions
# SUPABASE_ANON_KEY - Automatically available in Edge Functions
# SUPABASE_SERVICE_ROLE_KEY - Automatically available in Edge Functions

# Google Gemini API Key (for image generation)
# Get this from: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key

# Stripe Secret Key (for subscriptions)
